---
import Listing, { type PostMetadata } from '../components/listing.astro'
import Layout from '../layouts/layout.astro'
import { getCollection } from 'astro:content'
const posts = await getCollection('posts')

---

<style>
.listing-container {
  margin: 1.25rem 4.5rem;
}
</style>

<Layout>
  <main>
    <ul class="listing-container">
      {posts.map((post) => <Listing post={post.data} href={post.id} />)}
    </ul>
  </main>
</Layout>
