const posts = await getCollection('posts')

---

<style>
.listing-container {
  margin: 1.25rem 3rem;
}
</style>

<Layout>
  <main>
    <ul class="listing-container">
      <!-- {listings.map((post) => <Listing post={post} href="/post" />)} -->
      {posts.map((post) => <Listing post={post.data} href={post.id} />)}
    </ul>
  </main>
</Layout>
