---
import { getCollection, render } from 'astro:content'
import Titleblock from '../components/titleblock.astro'
import Layout from '../layouts/layout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}
const { post } = Astro.props
const { Content } = await render(post)
---

<style>
main {
  margin: 1.25rem 4.5rem;
}

.container {
  h1 {
    font-size: 1.3rem;
    font-weight: bold;
    margin-top: 2.1rem;
    margin-bottom: 1rem;
    position: relative;
    color: var(--color-fg-main);

    &:before {
      position: absolute;
      top: -1px;
      left: -1.4rem;
      color: var(--color-accent);
      content: "#";
      font-weight: bold;
      font-size: 1.4rem;
    }
  }

  h2 {
    font-size: 1.1rem;
    font-weight: bold;
    text-decoration: underline;
    letter-spacing: wide;
    margin-top: 1.9rem;
    margin-bottom: 0.9rem;
  }

  h3 {
    font-weight: bold;
    text-transform: uppercase;
    margin-top: 1.7rem;
    margin-bottom: 0.8rem;
    letter-spacing: wider;
  }

  p {
    margin: 0.25rem 0;
  }

  ol, ul, menu {
    list-style: disc;
    margin-left: 1rem;
  }

  pre {
    padding: 1.5rem;
    border-radius: 0.25rem;
  }
}
</style>

<Layout>
  <main>
    <Titleblock post={post.data} />
    <div class="container">
      <Content />
    </div>
  </main>
</Layout>
