---
import { getCollection, render } from 'astro:content'
import ContentWrapper from '../components/content-wrapper.astro'
import Titleblock from '../components/titleblock.astro'
import Layout from '../layouts/layout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}
const { post } = Astro.props
const { Content } = await render(post)
---

<style>
main {
  margin: 1.25rem 4.5rem;
  max-width: calc(1000px - 6rem);

  @media (width >= calc(1000px + 4.5rem)) {
    margin: 1.25rem auto;
  }
}
</style>

<Layout>
  <main>
    <Titleblock post={post} />
    <ContentWrapper>
      <Content />
    </ContentWrapper>
  </main>
</Layout>
