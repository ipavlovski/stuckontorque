---
import type { CollectionEntry } from 'astro:content'
import Tags from './tags.astro'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
---

<style>
.metadata {
  display: flex;
  align-items: center;
  justify-content: left;
  gap: 1rem;
  margin-top: 1.5rem;

  @media (width <= 800px) {
    :last-child {
      span {
        display: none;
      }
    }
  }
}

.title {
  font-size: 2.25rem;
  font-weight: bold;
  margin-top: 0.5rem;
  margin-bottom: 1.5rem;
  letter-spacing: 1px;
  text-transform: capitalize;

  @media (width <= 800px) {
    font-size: 1.5rem;
  }
}

.category {
  font-family: var(--font-alt);
  color: var(--color-fg-alt);
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  margin-right: auto;

  &:hover {
    color: var(--color-accent);
    cursor: pointer;
    transition: color 300ms ease;
  }
}

.created-at {
  font-family: var(--font-alt);
  color: var(--color-fg-alt);
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;

  &:hover {
    color: var(--color-accent);
    cursor: pointer;
    transition: color 300ms ease;
  }
}
</style>

<div>
  <div class="metadata">
    <span class="created-at">{post.data.date}</span>
    <span class="category">{post.data.category}</span>
    <Tags tags={post.data.tags} showText={true} />
  </div>

  <h1 class="title">{post.data.title}</h1>
</div>
