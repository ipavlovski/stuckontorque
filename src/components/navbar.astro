---
import { Icon } from 'astro-icon/components'
---

<style>
.navbar {
  position: sticky;
  top: 1.25rem;
  z-index: 100;
  margin: 1.25rem 3rem;
  max-width: calc(1200px - 3rem);

  @media (width >= calc(1200px + 3rem)) {
    margin: 1.25rem auto;
  }
}

.container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 0.5rem;
  padding: 0.5rem 1.5rem;
  box-shadow: 4px 4px 20px rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(16px);
}

.blog-logo {
  font-family: var(--font-logo);
  font-size: 1.25rem;
  letter-spacing: 1px;

  :hover {
    color: var(--color-accent);
    transition: color 300ms ease;
  }
}

.user-logo {
  font-size: 2rem;

  :hover {
    color: var(--color-accent);
    cursor: pointer;
    transition: color 300ms ease;
  }
}
</style>

<nav class="navbar">
  <div class="container">
    <div class="blog-logo"><a href="/"> Stuck On Torque </a></div>
    <div class="user-logo"><Icon name="tabler:user-circle" /></div>
  </div>
</nav>
